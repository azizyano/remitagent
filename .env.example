# Celo Network
CELO_RPC_URL=https://forno.celo.org
CELO_PRIVATE_KEY=your_private_key_here
CELO_WALLET_ADDRESS=your_wallet_address_here

# The Graph (Uniswap V3 on Celo)
GRAPH_API_KEY=your_subgraph_api_key

# 0x API (DEX Aggregation)
ZEROX_API_KEY=your_0x_api_key

# Off-chain FX Rates (Free tiers)
EXCHANGERATE_API_KEY=your_key  # exchangerate-api.com
FRANKFURTER_URL=https://api.frankfurter.app

# Notifications (Telegram)
# Get bot token from @BotFather
# Get chat ID from @userinfobot
TELEGRAM_BOT_TOKEN=your_bot_token
TELEGRAM_CHAT_ID=your_numeric_chat_id

# Agent Config
MIN_SPREAD_THRESHOLD=0.5  # Minimum spread % to trigger opportunity
CHECK_INTERVAL_SECONDS=300  # Check interval in seconds (300 = 5 min)

# Target Pairs - Examples:
# Basic (3 pairs): cUSD-cEUR,cUSD-cKES,cEUR-cKES
# Expanded (10 pairs): cUSD-cEUR,cUSD-cKES,cUSD-cCOP,cUSD-cNGN,cUSD-cREAL,cEUR-cKES,cEUR-cCOP,cEUR-cNGN,cKES-cCOP,cUSD-axlUSDC
TARGET_PAIRS=cUSD-cEUR,cUSD-cKES,cEUR-cKES

# Safety Settings
SLIPPAGE_PROTECTION=0.5  # Max slippage % on any trade
MAX_TRADE_SIZE_USD=1000  # Maximum trade size in USD
MIN_LIQUIDITY_DEPTH=10000  # Minimum pool TVL in USD
COOLDOWN_MINUTES=15  # Cooldown between trades on same pair
EMERGENCY_STOP_FILE=/tmp/remitagent_stop  # Touch file to halt agent

# Remote Control via Telegram
# Once running, send these commands to your bot:
# /start - Welcome message
# /help - Show available commands
# /status - Check agent status
# /stats - View trading statistics
# /stop or /emergency - Stop the agent immediately
